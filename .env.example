# --- Meridian Bank MCP server environment ---

# HTTP
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Public base URL of THIS server (no trailing slash). The canonical resource
# identifier (token audience) is PUBLIC_URL + "/mcp".
# Locally: http://localhost:8080 ; on Railway: https://<service>.up.railway.app
PUBLIC_URL=http://localhost:8080

# OAuth issuer. Defaults to PUBLIC_URL (co-located authorization server).
# Point this at an external AS (e.g. LLM Shield) to disable the local AS.
AUTH_ISSUER=http://localhost:8080

# Ed25519 private signing key as a JWK JSON string. If unset, a key is generated
# on boot (fine for dev; set a stable key in prod so tokens survive restarts).
# AUTH_SIGNING_KEY={"kty":"OKP","crv":"Ed25519","d":"...","x":"...","kid":"meridian-2026"}

# Secret used to sign the operator login-session cookie (any long random string).
COOKIE_SECRET=dev-cookie-secret-change-me

# Pre-registered OAuth client (the "Meridian copilot")
OAUTH_CLIENT_ID=meridian-copilot
OAUTH_CLIENT_SECRET=dev-client-secret-change-me
OAUTH_CLIENT_REDIRECT_URIS=http://localhost:3000/callback,http://127.0.0.1:3000/callback

# Database (Railway injects this; locally use the docker Postgres below)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/meridian

# Seed realistic demo data on boot (dev only; never default-on in prod)
SEED_ON_BOOT=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
